{
  "expo": {
    "name": "CalTrack",
    "slug": "caltrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#09090b"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "icon": "./assets/icon.png",
      "name": "CalTrack",
      "shortName": "CalTrack",
      "description": "AI-powered nutrition and fitness tracker",
      "bundler": "metro",
      "themeColor": "#09090b",
      "backgroundColor": "#09090b"
    }
  }
}
